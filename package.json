{
  "name": "harness",
  "version": "0.1.0",
  "description": "Portable skills and extensions repo for a Pi-style agent",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "agent",
    "skills",
    "extensions",
    "pi-extension",
    "pi-skill",
    "pi-theme"
  ],
  "files": [
    "AGENTS.md",
    "NOTICE",
    "README.md",
    "extensions/",
    "skills/",
    "themes/",
    "fixtures/",
    "manifests/",
    "scripts/",
    "vendor/"
  ],
  "pi": {
    "extensions": [
      "./extensions/context.ts",
      "./extensions/files.ts",
      "./extensions/harness-help.ts",
      "./extensions/repo-operator.ts",
      "./extensions/google-workspace.ts",
      "./extensions/browser-runtime.ts",
      "./extensions/review.ts",
      "./extensions/autoresearch.ts"
    ],
    "skills": [
      "./skills"
    ],
    "themes": [
      "./themes/harness.json"
    ]
  },
  "scripts": {
    "validate": "node scripts/validate-manifests.mjs",
    "evals": "node scripts/run-evals.mjs",
    "self-improve": "node scripts/open-pr.mjs",
    "bootstrap": "bash scripts/bootstrap-local.sh"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/r614/harness.git"
  },
  "homepage": "https://github.com/r614/harness",
  "bugs": {
    "url": "https://github.com/r614/harness/issues"
  },
  "license": "Apache-2.0"
}
