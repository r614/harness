[
  {
    "name": "calendar-list-upcoming",
    "kind": "calendar.listUpcoming",
    "input": {
      "timeMin": "2026-03-15T00:00:00Z",
      "timeMax": "2026-03-16T00:00:00Z",
      "maxResults": 10
    },
    "fixtures": {
      "calendar:listEvents": "fixtures/gws/calendar-events.json"
    },
    "expect": {
      "action": "calendar.list_upcoming",
      "count": 1,
      "firstEventId": "evt-1"
    }
  },
  {
    "name": "calendar-draft-create-requires-approval",
    "kind": "calendar.draftEvent",
    "input": {
      "summary": "Planning sync",
      "start": "2026-03-15T15:00:00Z",
      "end": "2026-03-15T15:30:00Z",
      "attendees": ["teammate@example.com"]
    },
    "expect": {
      "action": "calendar.create_event_draft",
      "approvalRequired": true,
      "summary": "Planning sync"
    }
  },
  {
    "name": "calendar-apply-approved-create",
    "kind": "calendar.applyDraft",
    "input": {
      "approved": true,
      "eventDraft": {
        "summary": "Planning sync",
        "start": "2026-03-15T15:00:00Z",
        "end": "2026-03-15T15:30:00Z",
        "attendees": ["teammate@example.com"],
        "location": "Meet",
        "description": "Agenda draft"
      }
    },
    "fixtures": {
      "calendar:createEvent": "fixtures/gws/calendar-create-result.json"
    },
    "expect": {
      "action": "calendar.create_event",
      "executed": true,
      "eventId": "evt-created-1"
    }
  }
]
