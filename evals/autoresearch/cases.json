[
  {
    "name": "reconstruct-state-from-jsonl",
    "runner": "reconstruct",
    "input": "fixtures/autoresearch/sample-session.jsonl",
    "expect": {
      "name": "Optimize tests v2",
      "metricName": "seconds",
      "metricUnit": "s",
      "bestDirection": "lower",
      "currentSegment": 1,
      "resultCount": 3,
      "baselineMetric": 9.8,
      "secondaryMetrics": ["heap_mb"]
    }
  },
  {
    "name": "init-experiment-writes-config",
    "runner": "init",
    "input": "fixtures/autoresearch/init-input.json",
    "expect": {
      "name": "Optimize tests",
      "metricName": "seconds",
      "metricUnit": "s",
      "bestDirection": "lower",
      "currentSegment": 0
    }
  },
  {
    "name": "run-experiment-captures-pass-failure-and-output",
    "runner": "run",
    "expect": {
      "passContains": "hello from run",
      "failExitCode": 7,
      "failPassed": false
    }
  },
  {
    "name": "log-experiment-keep-auto-commits",
    "runner": "log-keep",
    "expect": {
      "status": "keep",
      "committed": true,
      "resultCount": 1,
      "metric": 12.5
    }
  },
  {
    "name": "checks-failed-blocks-keep",
    "runner": "checks-gate",
    "expect": {
      "checksPass": false,
      "blocked": true
    }
  },
  {
    "name": "reinit-increments-segment",
    "runner": "reinit",
    "expect": {
      "currentSegment": 1,
      "resultCount": 1,
      "baselineMetric": 8.5
    }
  },
  {
    "name": "auto-resume-decision-respects-rate-limit-and-turn-limit",
    "runner": "resume-decision",
    "expect": {
      "ok": true,
      "rateLimited": false,
      "rateLimitedReason": "rate_limited",
      "turnLimit": false,
      "turnLimitReason": "turn_limit"
    }
  },
  {
    "name": "resume-message-includes-ideas-when-present",
    "runner": "resume-message",
    "expect": {
      "withIdeasIncludes": "autoresearch.ideas.md",
      "withoutIdeasIncludes": "autoresearch.md"
    }
  },
  {
    "name": "ideas-prune-removes-tried-and-deduplicates",
    "runner": "ideas-prune",
    "input": "fixtures/autoresearch/sample-ideas.md",
    "expect": {
      "remaining": 2,
      "contains": "Reuse compiled regex objects across runs"
    }
  },
  {
    "name": "append-idea-creates-backlog-entry",
    "runner": "append-idea",
    "expect": {
      "updated": true,
      "contains": "Move serialization off the hot path"
    }
  },
  {
    "name": "revert-helper-resets-working-tree",
    "runner": "revert",
    "expect": {
      "reverted": true,
      "clean": true
    }
  }
]
