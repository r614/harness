[
  {
    "name": "valid-change-set",
    "runner": "prepare-action",
    "input": "fixtures/repos/self-improvement-valid.json",
    "expect": {
      "allowed": true,
      "riskClassification": "medium",
      "requiredChecks": [
        "npm run validate",
        "npm run evals"
      ]
    },
    "expectChangedFilesFromInput": true
  },
  {
    "name": "disallowed-path",
    "runner": "prepare-action",
    "input": "fixtures/repos/self-improvement-invalid.json",
    "expect": {
      "allowed": false,
      "invalidTargets": [
        "package.json"
      ]
    }
  },
  {
    "name": "open-pr-script-structured-output",
    "runner": "open-pr",
    "input": "fixtures/repos/self-improvement-valid.json",
    "expect": {
      "allowed": true,
      "riskClassification": "medium",
      "requiredChecks": [
        "npm run validate",
        "npm run evals"
      ],
      "changedFiles": [
        "extensions/repo-operator.mjs",
        "evals/self-improvement/README.md",
        "fixtures/repos/self-improvement-valid.json"
      ]
    }
  }
]
